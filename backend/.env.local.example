# Local development environment variables.
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit it.

# Your GCP project ID (used by Firebase Admin and Vertex AI SDKs)
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# Firebase Emulator — set by `firebase emulators:start` automatically,
# but you can hardcode it here if needed.
FIRESTORE_EMULATOR_HOST="localhost:8081"
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"
FIREBASE_STORAGE_EMULATOR_HOST="localhost:9199"

# Where the locally running FastAPI server is (used by watcher.py)
BACKEND_URL="http://localhost:8000"

# Cloud Storage bucket name (used by the ingestion service)
PUBLIC_ASSETS_BUCKET="your-public-assets-bucket"
INGESTION_BUCKET="your-ingestion-bucket"

# Firestore database name (default is '(default)')
FIRESTORE_DATABASE="(default)"

# Optional: path to a service account JSON key for local Vertex AI calls
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
