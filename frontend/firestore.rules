rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isActiveUser() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == "active";
    }

    match /users/{userId} {
      allow read: if request.auth.uid == userId;
      // Client may only create its own document (on first sign-in) with status = "pending".
      // All subsequent updates (xp, completedChapterIds, lastActive, etc.) are performed
      // exclusively by the backend via the Admin SDK, which bypasses these rules.
      allow create: if request.auth.uid == userId
        && request.resource.data.status == "pending";
      allow update, delete: if false;
    }

    match /books/{bookId} {
      allow read: if isActiveUser();
      allow write: if false;
    }

    match /chapters/{chapterId} {
      allow read: if isActiveUser();
      allow write: if false;
    }

    match /exercise_attempts/{attemptId} {
      allow read: if isActiveUser() && resource.data.userId == request.auth.uid;
      allow create: if isActiveUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.evaluation == null
        && request.resource.data.status == "pending";
      allow update, delete: if false;
    }
  }
}
