rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Chapter assets (audio, images) — readable by any authenticated user.
    // Write access is denied; the content-cli writes via the GCS SDK
    // (Admin/service-account credentials) and bypasses these rules.
    //
    // Note: cross-service firestore.get() only works with the "(default)"
    // database, so we cannot check user status in the named "daskalo-db"
    // database from storage rules.  Active-user gating is enforced in
    // the frontend routing and backend Cloud Functions instead.
    match /chapters/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Own-word audio files — readable only by the owning user.
    // Written exclusively by the add-own-word Cloud Function via Admin SDK.
    match /users/{userId}/own_words/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Archives (raw content ZIPs) are never accessible from the client.
    match /archives/{allPaths=**} {
      allow read, write: if false;
    }

  }
}
